# =============================================================================
# CAS Incubator OS — Environment Variables
# Copy to .env.local and fill in your values.
# =============================================================================

# Clerk Authentication (clerk.com → API Keys)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# Clerk Webhooks (Clerk Dashboard → Webhooks → create endpoint)
CLERK_WEBHOOK_SECRET=whsec_...

# Supabase (Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Anthropic AI (console.anthropic.com → API Keys)
ANTHROPIC_API_KEY=sk-ant-...

# Resend (resend.com → API Keys — for transactional email)
RESEND_API_KEY=re_...

# Vercel Blob (Vercel Dashboard → Storage → Blob)
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_...

# Cron secret — secures /api/cron/risk-detect from unauthorized callers
# Generate with: openssl rand -hex 32
CRON_SECRET=your-random-secret-here
